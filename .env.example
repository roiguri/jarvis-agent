# Jarvis environment variables
# Copy this file to /app/secrets/.env and fill in the real values.
# That path is outside the repo and never committed.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id_here   # numeric ID

# --- Google Gemini (LLM) ---
GOOGLE_API_KEY=your_google_api_key_here

# --- Sonarr (TV downloads) ---
SONARR_URL=http://sonarr.local:8989
SONARR_API_KEY=your_sonarr_api_key_here

# --- Radarr (movie downloads) ---
RADARR_URL=http://radarr.local:7878
RADARR_API_KEY=your_radarr_api_key_here

# --- Prowlarr (indexer search) ---
PROWLARR_URL=http://prowlarr.local:9696
PROWLARR_API_KEY=your_prowlarr_api_key_here

# --- Jellyseerr (request tracking) ---
JELLYSEERR_URL=http://jellyseerr.local:5055
JELLYSEERR_API_KEY=your_jellyseerr_api_key_here

# --- Jellyfin (media server) ---
JELLYFIN_INTERNAL_URL=http://jellyfin.local:8096   # poster fetch (webhook notifier)
JELLYFIN_PUBLIC_URL=jellyfin.example.com           # shown in "Watch at ..." notifications

# --- Web search (Tavily) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- GitHub (project management) ---
GITHUB_TOKEN=your_github_pat_here   # classic PAT, 'repo' scope

# --- Google Health API (Pixel Watch: sleep, workouts, resting HR, HRV) ---
# One-time setup (GCP project, OAuth consent, minting the refresh token,
# terminal sanity-check): see tools/google_health/SETUP.md.
GOOGLE_HEALTH_CLIENT_ID=your_google_health_oauth_client_id_here
GOOGLE_HEALTH_CLIENT_SECRET=your_google_health_oauth_client_secret_here
GOOGLE_HEALTH_REFRESH_TOKEN=your_google_health_refresh_token_here

# --- Arbox gym API ---
ARBOX_ACCESS_TOKEN=your_arbox_jwt_access_token_here
ARBOX_WHITELABEL=your_gym_whitelabel_here   # gym's app brand identifier (request header)
ARBOX_BOX_ID=your_arbox_box_id_here
ARBOX_LOCATIONS_BOX_ID=your_arbox_locations_box_id_here
ARBOX_MEMBERSHIP_USER_ID=your_membership_user_id_here
